+DEFINE_API(bool, QueuePackage, ((const char*, repoName))
+  ((const char*, categoryName))((const char*, packageName))
+  ((const char*, versionName))((bool, pin))((bool, allowPrereleases))
+  ((char*, errorOut))((int, errorOut_sz)),
+R"(Queue a package for installation using ReaPack's native transaction engine.
+An empty version installs the latest stable version, or the latest version when
+allowPrereleases is true. Call ReaPack_ProcessQueue(true) after queueing all
+operations.)",
+{
+  try {
+    const Remote &remote = g_reapack->remote(repoName);
+    if(!remote) {
+      if(errorOut)
+        snprintf(errorOut, errorOut_sz, "repository not found");
+      return false;
+    }
+
+    Transaction *tx = g_reapack->setupTransaction(false);
+    if(!tx) {
+      if(errorOut)
+        snprintf(errorOut, errorOut_sz, "could not create transaction");
+      return false;
+    }
+
+    const IndexPtr &index = tx->loadIndex(remote);
+    if(!index) {
+      if(errorOut)
+        snprintf(errorOut, errorOut_sz, "repository index is unavailable");
+      return false;
+    }
+
+    const Package *package = index->find(categoryName, packageName);
+    if(!package) {
+      if(errorOut)
+        snprintf(errorOut, errorOut_sz, "package not found");
+      return false;
+    }
+
+    const Version *version = nullptr;
+    if(versionName && strlen(versionName) > 0)
+      version = package->findVersion(VersionName(versionName));
+    else
+      version = package->lastVersion(allowPrereleases);
+
+    if(!version) {
+      if(errorOut)
+        snprintf(errorOut, errorOut_sz, "package version not found");
+      return false;
+    }
+
+    const int flags =
+      (pin ? Registry::Entry::PinnedFlag : 0) |
+      (allowPrereleases ? Registry::Entry::BleedingEdgeFlag : 0);
+    const Registry::Entry &current = tx->registry()->getEntry(package);
+
+    if(current && current.version == version->name() && current.flags == flags)
+      return true;
+
+    tx->install(version, flags);
+    return true;
+  }
+  catch(const reapack_error &e) {
+    if(errorOut)
+      snprintf(errorOut, errorOut_sz, "%s", e.what());
+    return false;
+  }
+});
+
+DEFINE_API(bool, QueueUninstallPackage, ((const char*, repoName))
+  ((const char*, categoryName))((const char*, packageName))
+  ((char*, errorOut))((int, errorOut_sz)),
+R"(Queue an installed package for removal using ReaPack's native transaction
+engine. Missing packages are treated as already absent. Call
+ReaPack_ProcessQueue(true) after queueing all operations.)",
+{
+  try {
+    Transaction *tx = g_reapack->setupTransaction(false);
+    if(!tx) {
+      if(errorOut)
+        snprintf(errorOut, errorOut_sz, "could not create transaction");
+      return false;
+    }
+
+    for(const Registry::Entry &entry : tx->registry()->getEntries(repoName)) {
+      if(entry.category == categoryName && entry.package == packageName) {
+        tx->uninstall(entry);
+        break;
+      }
+    }
+
+    return true;
+  }
+  catch(const reapack_error &e) {
+    if(errorOut)
+      snprintf(errorOut, errorOut_sz, "%s", e.what());
+    return false;
+  }
+});
